{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "lib": ["es2020"],
    "module": "commonjs",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "build",
    "rootDir": "..",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2017",
    "types": ["node"]
  },
  "include": ["src/**/*", "types/**/*"]
}
