version: 2
updates:
  - package-ecosystem: npm
    directory: /
    schedule:
      interval: weekly
    groups:
      npm-development:
        dependency-type: development
        patterns:
          - '*'

  - package-ecosystem: npm
    directory: /playground
    schedule:
      interval: weekly
    groups:
      playground-npm:
        patterns:
          - '*'

  - package-ecosystem: github-actions
    directory: /
    schedule:
      interval: weekly
