{
  "name": "capacitor-tcpclient",
  "description": "Capacitor Example App - TCP Client",
  "author": "DevIOArts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "build": {
    "appId": "com.devioarts.example.tcpclient",
    "productName": "cap-tcpclient",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/vite.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "tsc -b && vite build",
    "build:electron": "npx cap-electron prepare",

    "lint": "eslint .",
    "preview": "vite preview",
    "copy": "npx cap copy",
    "sync": "npx cap sync",
    "open-ios": "npx cap open ios",
    "open-android": "npx cap open android",
    "open-electron": "npx cap-electron open",

    "electron:dist": "npm run build && npx cap-electron sync && cd electron && npm run dist",
    "electron:dist:win": "npm run build && npx cap-electron sync && cd electron && npm run dist:win",
    "electron:dist:mac": "npm run build && npx cap-electron sync && cd electron && npm run dist:mac",
    "electron:dist:lnx": "npm run build && npx cap-electron sync && cd electron && npm run dist:linux"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@devioarts/capacitor-tcpclient": "file:..",
    "@tailwindcss/vite": "^4.3.0",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@devioarts/capacitor-electron": "github:devioarts/capacitor-electron",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/electron": "^1.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
