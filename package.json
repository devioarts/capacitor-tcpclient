{
  "name": "@devioarts/capacitor-tcpclient",
  "version": "0.0.3",
  "description": "TCP Client for Capacitor working on Android, iOS and Electron",
  "keywords": [
    "capacitor",
    "android",
    "ios",
    "electron",
    "plugin",
    "native",
    "tcp client",
    "tcp-client"
  ],
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "electron/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "DevioartsCapacitorTcpclient.podspec"
  ],
  "author": "Andy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devioarts/capacitor-tcpclient.git"
  },
  "bugs": {
    "url": "https://github.com/devioarts/capacitor-tcpclient/issues"
  },
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "xcodebuild -scheme DevioartsCapacitorTcpclient -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "eslint": "eslint .",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api TCPClientPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs && npm run build-electron",
    "build-electron": "tsc --project electron/tsconfig.json && rollup -c electron/rollup.config.mjs && rimraf ./electron/build",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "release": "npm publish --access public"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.0",
    "@capacitor/core": "8.4.0",
    "@capacitor/docgen": "0.3.1",
    "@capacitor/ios": "8.4.0",
    "@ionic/prettier-config": "4.0.0",
    "@ionic/swiftlint-config": "2.0.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.4",
    "prettier-plugin-java": "2.9.7",
    "rimraf": "6.1.3",
    "rollup": "4.61.1",
    "swiftlint": "2.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "electron": "42.3.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    },
    "electron": {
      "src": "electron"
    }
  }
}
